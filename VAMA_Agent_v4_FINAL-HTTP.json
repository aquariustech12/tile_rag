    {
      "parameters": {
        "jsCode": "// Formatear respuesta de sucursales\nconst sucursales = $json;\nlet texto = 'Aquí están nuestras sucursales:\\n\\n';\nsucursales.forEach((s, i) => {\n  texto += `${i+1}. ${s.nombre}\\n   📍 ${s.direccion}\\n   📞 ${s.telefono}\\n   🕒 ${s.horario}\\n\\n`;\n});\nreturn { ...$json, respuesta: texto };"
