    {
      "parameters": {
        "jsCode": "// Datos del webhook (Extraer Datos Webhook)\nconst webhook = $node['Extraer Datos Webhook'].json;\n\n// Datos de la API (Code2, que contiene los datos del usuario)\nconst api = $node['Get User State v2'].json;\n\n// Verificar si la API devolvió datos válidos (debe tener telefono)\nconst usuarioExiste = api && api.telefono;\n\n// Función para parsear JSON de forma segura\nfunction safeParse(str) {\n  if (!str || typeof str !== 'string') return [];\n  try {\n    const parsed = JSON.parse(str);\n    return Array.isArray(parsed) ? parsed : [];\n  } catch (e) {\n    return [];\n  }\n}\n\nreturn {\n  telefono: webhook.telefono,\n  nombre: webhook.nombre,\n  mensaje: webhook.mensaje,\n  estado: usuarioExiste ? api.estado : \"inicio\",\n  m2: usuarioExiste ? api.m2 : 0,\n  carrito: usuarioExiste ? safeParse(api.carrito) : [],\n  ultimos_productos: usuarioExiste ? safeParse(api.ultimos_productos) : [],\n  ultima_busqueda: usuarioExiste ? api.ultima_busqueda : \"\"\n};"
      },
