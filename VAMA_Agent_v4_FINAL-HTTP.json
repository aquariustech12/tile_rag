    {
      "parameters": {
        "jsCode": "const llm = $json;\nconst userData = $node['Merge State'].json; // Ajusta el nombre si es otro\n\n// Normalizar intent\nlet intent = llm.intent ? llm.intent.toLowerCase().trim() : 'buscar';\nif (!['saludo','buscar','seleccion','sucursales','envio','checkout','quitar'].includes(intent)) {\n  intent = 'buscar';\n}\n\n// Extraer entidades\nconst entidades = llm.entidades || {};\n\nreturn {\n  ...userData,\n  intent: intent,\n  entidades: entidades\n};"
