        "jsCode": "const url = $json.url;\nconst options = {\n  method: 'GET',\n  url: url,\n  json: true,  // Para que la respuesta se devuelva como objeto\n  rejectUnauthorized: false  // Ignorar SSL si es necesario (opcional)\n};\n\ntry {\n  const response = await this.helpers.httpRequest(options);\n  return response;\n} catch (error) {\n  // Si es 404, devolvemos un objeto indicando que no existe\n  if (error.statusCode === 404) {\n    return {\n      error: \"not_found\",\n      telefono: $node['Extraer Datos Webhook'].json.telefono\n    };\n  }\n  // Si es otro error, lo lanzamos para que n8n lo muestre\n  throw new Error(`HTTP request failed: ${error.message}`);\n}"
