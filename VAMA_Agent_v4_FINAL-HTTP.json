        1632
      ]
    },
    {
      "parameters": {
        "jsCode": "const productos = $json.productos;\n\n// Si no hay productos, devolver error pero CONSERVAR datos del usuario\nif (!productos || productos.length === 0) {\n  return { \n    respuesta: 'Lo siento, no encontré productos con esas características. ¿Podrías darme más detalles? (color, medida, tipo)',\n    telefono: $json.telefono,\n    nombre: $json.nombre,\n    mensaje: $json.mensaje,\n    m2: $json.m2 || 0,\n    carrito: $json.carrito || [],\n    estado: $json.estado || 'inicio',\n    ultimos_productos: [],\n    nuevo_estado: 'inicio'\n  };\n}\n\n// Guardar ultimos_productos en estado\nconst ultimos = productos.slice(0,3);\nlet texto = 'Aquí están las opciones que encontré:\\n';\nfor (let i = 0; i < ultimos.length; i++) {\n  const p = ultimos[i];\n  texto += `\\nOpción ${i+1}:\\n- Producto: ${p.descripcion}\\n`;\n  if (p.formato) texto += `- Formato: ${p.formato}\\n`;\n  if (p.color) texto += `- Color: ${p.color}\\n`;\n  if (p.m2_caja) texto += `- Rendimiento: ${p.m2_caja} m² por caja\\n`;\n  if (p.precio) texto += `- Precio: $${p.precio.toFixed(2)}\\n`;\n}\n\nconst m2 = $json.m2 || 0;\nif (m2) texto += `\\nPara tus ${m2} m², ¿cuál te interesa? (dime el número o el nombre)`;\nelse texto += '\\n¿Cuál te interesa? (dime el número o el nombre)';\n\n// ✅ DEVOLVER TODO: respuesta + datos del usuario + nuevo estado\nreturn { \n  respuesta: texto, \n  ultimos_productos: ultimos,\n  telefono: $json.telefono,\n  nombre: $json.nombre,\n  mensaje: $json.mensaje,\n  m2: $json.m2 || 0,\n  carrito: $json.carrito || [],\n  estado: $json.estado || 'inicio',\n  nuevo_estado: 'cotizando', // ← Importante: ahora estamos cotizando\n};"
      },
      "id": "3815d980-b911-47d4-9718-7a10f8e3bb42",
      "name": "Format Búsqueda",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1792,
        1728
      ]
    },
    {
      "parameters": {
        "jsCode": "// Obtener datos del usuario desde Merge State (siempre actualizado)\nconst usuario = $node['Merge State'].json;\n// Usar ultimos_productos del objeto actual si existen, sino del usuario\nconst ultimos = ($json.ultimos_productos && $json.ultimos_productos.length) ? $json.ultimos_productos : usuario.ultimos_productos;\n\nconst entidades = $json.entidades || {};\nlet productoSeleccionado = null;\n\n// 1. Por número (entidades.opcion_numero o número en mensaje)\nlet num = entidades.opcion_numero;\nif (!num) {\n  const match = $json.mensaje.toLowerCase().match(/\\b([1-3])\\b/);\n  if (match) num = parseInt(match[1]);\n}\nif (num && num >= 1 && num <= ultimos.length) {\n  productoSeleccionado = ultimos[num - 1];\n}\n\n// 2. Por nombre usando entidades\nif (!productoSeleccionado && (entidades.producto_tipo || entidades.color)) {\n  const tipo = entidades.producto_tipo?.toLowerCase() || '';\n  const color = entidades.color?.toLowerCase() || '';\n  productoSeleccionado = ultimos.find(p => {\n    const desc = p.descripcion?.toLowerCase() || '';\n    return (tipo && desc.includes(tipo)) || (color && desc.includes(color));\n  });\n}\n\n// 3. Fallback: buscar en el mensaje\nif (!productoSeleccionado) {\n  const palabrasClave = $json.mensaje.toLowerCase().replace(/quiero|el|la|los|las|ese|esa|ese|producto|opcion/gi, '').trim();\n  if (palabrasClave) {\n    productoSeleccionado = ultimos.find(p => p.descripcion.toLowerCase().includes(palabrasClave));\n  }\n}\n\nif (!productoSeleccionado) {\n  return {\n    ...$json,\n    respuesta: 'No encontré el producto que mencionas. Por favor dime el número de la opción (1,2,3) o el nombre exacto que apareció en la lista.'\n  };\n}\n\n// Calcular cantidad (si es superficie y hay m2)\nconst esSuperficie = ['nacionales','importados','muros'].includes(productoSeleccionado.coleccion);\nlet cantidad = 1;\nif (esSuperficie && $json.m2 && productoSeleccionado.m2_caja) {\n  cantidad = Math.ceil($json.m2 / productoSeleccionado.m2_caja);\n}\n\nconst item = {\n  codigo: productoSeleccionado.codigo,\n  descripcion: productoSeleccionado.descripcion,\n  cantidad: cantidad,\n  precio_unitario: productoSeleccionado.precio,\n  subtotal: (productoSeleccionado.precio || 0) * cantidad\n};\n\nconst carritoActual = [...($json.carrito || [])];\ncarritoActual.push(item);\nconst total = carritoActual.reduce((sum, i) => sum + (i.subtotal || 0), 0);\n\nconst respuesta = `¡Listo! He añadido ${cantidad} unidad(es) de ${productoSeleccionado.descripcion} a tu carrito.\\nSubtotal: $${item.subtotal.toFixed(2)}\\nTotal acumulado: $${total.toFixed(2)}\\n\\n¿Necesitas algo más o quieres ver el total?`;\n\nreturn {\n  ...$json,\n  ultimos_productos: ultimos,   // asegurar que se mantiene\n  respuesta,\n  nuevo_carrito: carritoActual, // array\n  nuevo_estado: 'cotizando'\n};"
      },
