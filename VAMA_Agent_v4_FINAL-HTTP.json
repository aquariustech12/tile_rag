    {
      "parameters": {
        "jsCode": "const carrito = $json.carrito;\nlet total = 0;\nlet lineas = ['**Resumen de tu cotización:**\\n'];\nfor (const item of carrito) {\n  const subtotal = (item.precio_unitario || 0) * item.cantidad;\n  total += subtotal;\n  lineas.push(`• ${item.descripcion}: ${item.cantidad} x $${item.precio_unitario?.toFixed(2)} = $${subtotal.toFixed(2)}`);\n}\nlineas.push(`\\n**TOTAL: $${total.toFixed(2)}**`);\nif ($json.pdf_url) {\n  lineas.push(`\\n📄 Descarga tu cotización aquí: ${$json.pdf_url}`);\n}\nlineas.push('\\n¿Te parece bien? ¿Confirmamos disponibilidad?');\n\nreturn { ...$json, respuesta: lineas.join('\\n'), nuevo_estado: 'esperando_confirmacion' };"
      },
