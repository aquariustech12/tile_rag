      "id": "search_products",
      "name": "Search Products",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1650,
        700
      ]
    },
    {
      "parameters": {
        "jsCode": "const productos = $json.productos;\nif (!productos || productos.length === 0) {\n  return { respuesta: 'Lo siento, no encontr\u00e9 productos con esas caracter\u00edsticas. \u00bfPodr\u00edas darme m\u00e1s detalles? (color, medida, tipo)' };\n}\n\n// Guardar ultimos_productos en estado (se har\u00e1 despu\u00e9s)\nconst ultimos = productos.slice(0,3);\nlet texto = 'Aqu\u00ed est\u00e1n las opciones que encontr\u00e9:\\n';\nfor (let i = 0; i < ultimos.length; i++) {\n  const p = ultimos[i];\n  texto += `\\nOpci\u00f3n ${i+1}:\\n- Producto: ${p.descripcion}\\n`;\n  if (p.formato) texto += `- Formato: ${p.formato}\\n`;\n  if (p.color) texto += `- Color: ${p.color}\\n`;\n  if (p.m2_caja) texto += `- Rendimiento: ${p.m2_caja} m\u00b2 por caja\\n`;\n  if (p.precio) texto += `- Precio: $${p.precio.toFixed(2)}\\n`;\n}\nconst m2 = $json.m2 || 0;\nif (m2) texto += `\\nPara tus ${m2} m\u00b2, \u00bfcu\u00e1l te interesa? (dime el n\u00famero o el nombre)`;\nelse texto += '\\n\u00bfCu\u00e1l te interesa? (dime el n\u00famero o el nombre)';\n\nreturn { respuesta: texto, ultimos_productos: ultimos };"
      },
      "id": "format_busqueda",
      "name": "Format B\u00fasqueda",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1850,
        700
      ]
    },
    {
      "parameters": {
        "jsCode": "// Manejo de selecci\u00f3n\nconst mensaje = $json.mensaje.toLowerCase();\nconst ultimos = $json.ultimos_productos;\nlet productoSeleccionado = null;\n\n// Por n\u00famero\nif (['1','2','3'].includes(mensaje)) {\n  const idx = parseInt(mensaje) - 1;\n  if (idx < ultimos.length) productoSeleccionado = ultimos[idx];\n} else {\n  // Por nombre\n  productoSeleccionado = ultimos.find(p => p.descripcion.toLowerCase().includes(mensaje));\n}\n\nif (!productoSeleccionado) {\n  return { respuesta: 'No entend\u00ed cu\u00e1l producto elegiste. Por favor dime el n\u00famero (1,2,3) o el nombre.' };\n}\n\n// Calcular cantidad (si es superficie y hay m2)\nconst esSuperficie = ['nacionales','importados','muros'].includes(productoSeleccionado.coleccion);\nlet cantidad = 1;\nif (esSuperficie && $json.m2 && productoSeleccionado.m2_caja) {\n  cantidad = Math.ceil($json.m2 / productoSeleccionado.m2_caja);\n}\n\nconst item = {\n  codigo: productoSeleccionado.codigo,\n  descripcion: productoSeleccionado.descripcion,\n  cantidad: cantidad,\n  precio_unitario: productoSeleccionado.precio,\n  subtotal: (productoSeleccionado.precio || 0) * cantidad\n};\n\nconst carritoActual = [...$json.carrito];\ncarritoActual.push(item);\nconst total = carritoActual.reduce((sum, i) => sum + (i.subtotal || 0), 0);\n\nconst respuesta = `\u00a1Listo! He a\u00f1adido ${cantidad} unidad(es) de ${productoSeleccionado.descripcion} a tu carrito.\\nSubtotal: $${item.subtotal.toFixed(2)}\\nTotal acumulado: $${total.toFixed(2)}\\n\\n\u00bfNecesitas algo m\u00e1s o quieres ver el total?`;\n\nreturn { respuesta, nuevo_carrito: carritoActual, nuevo_estado: 'cotizando' };"
      },
      "id": "seleccion",
      "name": "Selecci\u00f3n",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1850,
        800
      ]
    },
