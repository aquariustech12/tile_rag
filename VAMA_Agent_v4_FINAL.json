    {
      "parameters": {
        "jsCode": "// Combinar datos de webhook con estado del usuario\nconst webhookData = $input.first().json;\nlet userState = {};\nif ($input.length > 1) {\n  userState = $input.item(1).json;\n}\n\nreturn {\n  telefono: webhookData.messages[0].from,\n  nombre: webhookData.contacts[0].profile.name,\n  mensaje: webhookData.messages[0].text.body,\n  estado: userState.estado || 'inicio',\n  carrito: userState.carrito ? JSON.parse(userState.carrito) : [],\n  m2: userState.m2 || 0,\n  ultimos_productos: userState.ultimos_productos ? JSON.parse(userState.ultimos_productos) : [],\n  ultima_busqueda: userState.ultima_busqueda || ''\n};"
      },
      "id": "merge_state",
      "name": "Merge State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        300
