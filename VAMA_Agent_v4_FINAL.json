        1450,
        200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "\u00a1Listo! Empezamos una cotizaci\u00f3n nueva. \u00bfQu\u00e9 material necesitas?"
      },
      "id": "respond_reset",
      "name": "Respond Reset",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1650,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Detectar intenciones\nconst msg = $json.mensaje.toLowerCase();\nconst estado = $json.estado;\n\nlet intent = 'buscar';\n\n// 1. Ubicaci\u00f3n / ciudad\nconst ciudades = ['culiac\u00e1n','culiacan','los mochis','mochis','guasave','mazatl\u00e1n'];\nif (ciudades.some(c => msg.includes(c))) {\n  intent = 'sucursales';\n}\n// 2. Preguntas de env\u00edo / tiempo\nelse if (msg.includes('tarda') || msg.includes('env\u00edo') || msg.includes('domicilio') || msg.includes('disponibilidad')) {\n  intent = 'envio';\n}\n// 3. Saludo\nelse if (msg.includes('hola') || msg.includes('buen dia') || msg.includes('saludos')) {\n  intent = 'saludo';\n}\n// 4. Checkout\nelse if (msg.includes('total') || msg.includes('pagar') || msg.includes('resumen') || msg.includes('cotizacion') && $json.carrito.length > 0) {\n  intent = 'checkout';\n}\n// 5. Selecci\u00f3n (si hay productos mostrados y el mensaje es n\u00famero o nombre de producto)\nelse if ($json.ultimos_productos.length > 0) {\n  // Si el mensaje es un n\u00famero 1-3 o coincide con alg\u00fan nombre\n  const nums = ['1','2','3'];\n  if (nums.includes(msg) || $json.ultimos_productos.some(p => p.descripcion.toLowerCase().includes(msg))) {\n    intent = 'seleccion';\n  }\n}\n\nreturn { ...$json, intent };"
      },
      "id": "detect_intent",
      "name": "Detect Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        400
      ]
    },
    {
      "parameters": {
        "mode": "expression",
        "outputCount": 6,
        "jsExpression": "{{ $json.intent === 'sucursales' ? 0 : $json.intent === 'envio' ? 1 : $json.intent === 'saludo' ? 2 : $json.intent === 'checkout' ? 3 : $json.intent === 'seleccion' ? 4 : 5 }}"
      },
      "id": "switch_intent",
      "name": "Switch Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        1450,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://agente3.aegis-oceanit.work/sucursales",
        "authentication": "none",
        "sendQuery": false,
        "options": {}
      },
      "id": "get_sucursales",
      "name": "Get Sucursales",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1650,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Formatear respuesta de sucursales\nconst sucursales = $json;\nlet texto = 'Aqu\u00ed est\u00e1n nuestras sucursales:\\n\\n';\nsucursales.forEach((s, i) => {\n  texto += `${i+1}. ${s.nombre}\\n   \ud83d\udccd ${s.direccion}\\n   \ud83d\udcde ${s.telefono}\\n   \ud83d\udd52 ${s.horario}\\n\\n`;\n});\nreturn { respuesta: texto };"
      },
      "id": "format_sucursales",
      "name": "Format Sucursales",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1850,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "return { respuesta: 'Nuestros tiempos de entrega var\u00edan seg\u00fan la ubicaci\u00f3n. En Culiac\u00e1n, Los Mochis y Guasave realizamos env\u00edos en 24-48 horas h\u00e1biles. Para otras zonas, consulta con tu sucursal m\u00e1s cercana. \u00bfNecesitas m\u00e1s informaci\u00f3n?' };"
      },
      "id": "resp_envio",
      "name": "Respuesta Env\u00edo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const nombre = $json.nombre || 'Cliente';\nreturn { respuesta: `\u00a1Hola ${nombre}! \u00bfEn qu\u00e9 puedo ayudarte hoy? Estamos buscando materiales para construcci\u00f3n.` };"
      },
      "id": "resp_saludo",
      "name": "Respuesta Saludo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://agente3.aegis-oceanit.work/generar_pdf",
        "authentication": "none",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "user_id",
              "value": "={{ $json.telefono }}"
            },
            {
              "name": "carrito",
              "value": "={{ $json.carrito }}"
            },
            {
              "name": "nombre",
              "value": "={{ $json.nombre }}"
            }
          ]
        },
        "options": {}
      },
      "id": "generate_pdf",
      "name": "Generate PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        1650,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "const carrito = $json.carrito;\nlet total = 0;\nlet lineas = ['**Resumen de tu cotizaci\u00f3n:**\\n'];\nfor (const item of carrito) {\n  const subtotal = (item.precio_unitario || 0) * item.cantidad;\n  total += subtotal;\n  lineas.push(`\u2022 ${item.descripcion}: ${item.cantidad} x $${item.precio_unitario?.toFixed(2)} = $${subtotal.toFixed(2)}`);\n}\nlineas.push(`\\n**TOTAL: $${total.toFixed(2)}**`);\nif ($json.pdf_url) {\n  lineas.push(`\\n\ud83d\udcc4 Descarga tu cotizaci\u00f3n aqu\u00ed: ${$json.pdf_url}`);\n}\nlineas.push('\\n\u00bfTe parece bien? \u00bfConfirmamos disponibilidad?');\n\nreturn { respuesta: lineas.join('\\n'), nuevo_estado: 'esperando_confirmacion' };"
      },
      "id": "format_checkout",
      "name": "Format Checkout",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1850,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://agente3.aegis-oceanit.work/buscar",
        "authentication": "none",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $json.mensaje }}"
            },
            {
              "name": "m2",
              "value": "={{ $json.m2 }}"
